PKG_FFLAGS = -J. -I.

C_OBJS = sparsegl_init.o
F_OBJS = spmatmul.o sgl_subfuns.o log_sgl_subfuns.o sparsegl.o sparsegllog.o wsgl.o

$(SHLIB): $(F_OBJS) $(C_OBJS)

